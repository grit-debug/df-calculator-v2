<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DemFabrika — Giriş</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Segoe UI', system-ui, sans-serif;
    background: #f5f6fa;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .card {
    background: #fff;
    border: 1px solid #dde2f0;
    border-radius: 16px;
    padding: 2.5rem 2rem;
    width: 100%;
    max-width: 380px;
    box-shadow: 0 4px 24px rgba(26,39,68,.1);
  }
  .logo-wrap {
    background: #1a2744;
    border-radius: 12px;
    padding: 1rem 1.5rem;
    margin-bottom: 1.75rem;
    text-align: center;
  }
  .logo-wrap img { height: 28px; filter: brightness(0) invert(1); }
  h1 { font-size: 18px; font-weight: 700; color: #1a2744; margin-bottom: .25rem; }
  p  { font-size: 13px; color: #8a94b0; margin-bottom: 1.75rem; }
  .field { display: flex; flex-direction: column; gap: 5px; margin-bottom: 1rem; }
  .field label { font-size: 12px; font-weight: 600; color: #4a5578; }
  .field input {
    padding: 10px 12px; border: 1px solid #c4ccde;
    border-radius: 10px; font-size: 14px; background: #f5f6fa;
    color: #1a2744; outline: none; transition: border-color .15s;
  }
  .field input:focus { border-color: #2d6be4; background: #fff; box-shadow: 0 0 0 3px rgba(45,107,228,.1); }
  .btn {
    width: 100%; padding: 11px; background: #1a2744; color: #fff;
    border: none; border-radius: 10px; font-size: 14px; font-weight: 600;
    cursor: pointer; margin-top: .5rem; transition: background .15s;
  }
  .btn:hover { background: #253460; }
  .error {
    background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px;
    padding: .6rem .9rem; font-size: 13px; color: #b91c1c;
    margin-bottom: 1rem; display: none;
  }
</style>
</head>
<body>
<div class="card">
  <div class="logo-wrap">
    <img src="data:image/png;base64," alt="DemFabrika">
  </div>
  <h1>Hoş geldiniz</h1>
  <p>Devam etmek için giriş yapın</p>

  <div class="error" id="error-msg"></div>

  <div class="field">
    <label>E-posta</label>
    <input type="email" id="email" placeholder="ornek@sirket.com" autocomplete="username">
  </div>
  <div class="field">
    <label>Şifre</label>
    <input type="password" id="sifre" placeholder="••••••••" autocomplete="current-password">
  </div>
  <button class="btn" onclick="girisYap()">Giriş Yap</button>
</div>

<script>
// Zaten giriş yapılmışsa yönlendir
if (localStorage.getItem('df_token')) {
  window.location.href = '/app.html';
}

document.getElementById('sifre').addEventListener('keydown', e => {
  if (e.key === 'Enter') girisYap();
});

async function girisYap() {
  const email = document.getElementById('email').value.trim();
  const sifre = document.getElementById('sifre').value;
  const errEl = document.getElementById('error-msg');
  errEl.style.display = 'none';

  if (!email || !sifre) {
    errEl.textContent = 'E-posta ve şifre gerekli.';
    errEl.style.display = 'block';
    return;
  }

  try {
    const res = await fetch('/api/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, sifre })
    });
    const data = await res.json();
    if (!res.ok) {
      errEl.textContent = data.detail || 'Giriş başarısız.';
      errEl.style.display = 'block';
      return;
    }
    localStorage.setItem('df_token', data.token);
    localStorage.setItem('df_ad', data.ad);
    window.location.href = '/app.html';
  } catch(e) {
    errEl.textContent = 'Sunucuya bağlanılamadı.';
    errEl.style.display = 'block';
  }
}
</script>
</body>
</html>
